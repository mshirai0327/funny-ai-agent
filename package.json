{
  "name": "claude-notify",
  "publisher": "mshirai0327",
  "displayName": "Claude Notify",
  "description": "Cute anime character popup notifications when AI coding tasks complete",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mshirai0327/funny-ai-agent.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "files": [
    "src/**",
    "README.md"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeNotify.testPopup",
        "title": "Claude Notify: Test Popup"
      }
    ],
    "configuration": {
      "title": "Claude Notify",
      "properties": {
        "claudeNotify.character": {
          "type": "string",
          "enum": ["hana", "kira", "mochi", "random"],
          "default": "random",
          "description": "Character to display in popup (random picks one each time)"
        },
        "claudeNotify.displayDuration": {
          "type": "number",
          "default": 5000,
          "description": "How long (ms) the popup stays visible before auto-closing"
        }
      }
    }
  },
  "scripts": {
    "start": "npm --prefix claude-notify-app start",
    "vscode:prepublish": "npm run lint",
    "lint": "echo 'no linter configured'"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0"
  }
}
